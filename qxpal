#!/bin/bash
# QXPal - Linux Audio Optimization Framework CLI Wrapper
# GP-2.0 License
set -euo pipefail

VERSION="0.1.0"

# Log colors
NC='\033[0m'
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
WHITE='\033[1;37m'

log_info() { echo -e "${BLUE}[INFO]${NC} $*"; }
log_success() { echo -e "${GREEN}[SUCCESS]${NC} $*"; }
log_warn() { echo -e "${YELLOW}[WARNING]${NC} $*"; }
log_error() { echo -e "${RED}[ERROR]${NC} $*"; }

# 1. Resolve asset path (Local vs Global install)
if [ -d "/usr/local/share/qxpal/scripts" ]; then
    BASE_DIR="/usr/local/share/qxpal"
else
    # Fallback to local source directory
    BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
fi

SCRIPTS_DIR="$BASE_DIR/scripts"

# Make sure scripts have executable permissions in current session
chmod +x "$SCRIPTS_DIR"/*.sh 2>/dev/null || true

show_usage() {
    echo -e "${WHITE}QXPal Audio Optimizer - CLI Interface${NC}"
    echo "Usage: qxpal <command> [options]"
    echo ""
    echo "Commands:"
    echo "  install      Install QXPal to system (requires sudo)"
    echo "  optimize     Automatically detect profiles and apply tuning"
    echo "  diagnose     Display active hardware & service statuses"
    echo "  benchmark    Perform real-time scheduler & latency audits"
    echo "  backup       Safely archive audio stack parameters"
    echo "  restore      Fully revert all QXPal modifications"
    echo "  uninstall    Uninstall QXPal from system (requires sudo)"
    echo "  version      Print QXPal version"
    echo ""
}

cmd_version() {
    echo "QXPal version $VERSION"
    echo "License: GPL-2.0"
}

cmd_install() {
    if [ -f "$BASE_DIR/install.sh" ]; then
        exec "$BASE_DIR/install.sh"
    elif [ -f "/usr/local/share/qxpal/install.sh" ]; then
        exec "/usr/local/share/qxpal/install.sh"
    else
        log_error "Install script not found. Are you running from the repository folder?"
        exit 1
    fi
}

cmd_uninstall() {
    if [ -f "$BASE_DIR/uninstall.sh" ]; then
        exec "$BASE_DIR/uninstall.sh"
    elif [ -f "/usr/local/share/qxpal/uninstall.sh" ]; then
        exec "/usr/local/share/qxpal/uninstall.sh"
    else
        log_error "Uninstall script not found."
        exit 1
    fi
}

cmd_optimize() {
    # Safety Backup first
    log_info "Creating system backup before applying configurations..."
    bash "$SCRIPTS_DIR/backup.sh"
    
    if [ "$EUID" -eq 0 ]; then
        log_info "Applying system-level optimizations (ALSA & PipeWire configurations)..."
        bash "$SCRIPTS_DIR/apply_alsa.sh"
        bash "$SCRIPTS_DIR/apply_pipewire.sh"
        log_success "System-wide optimizations successfully applied."
        log_warn "To apply user-space DSP adjustments (EasyEffects), please rerun 'qxpal optimize' as your normal desktop user."
    else
        log_info "Applying user-level optimizations (PipeWire & EasyEffects configurations)..."
        bash "$SCRIPTS_DIR/apply_pipewire.sh"
        bash "$SCRIPTS_DIR/apply_easyeffects.sh"
        log_success "User-space optimizations successfully applied."
        log_warn "If you have not done so, run 'sudo qxpal optimize' once to apply ALSA and power-saving overrides."
    fi
}

# Main command routing
if [ $# -lt 1 ]; then
    show_usage
    exit 0
fi

COMMAND="$1"
shift

case "$COMMAND" in
    version)
        cmd_version
        ;;
    diagnose)
        exec bash "$SCRIPTS_DIR/diagnostics.sh"
        ;;
    benchmark)
        exec bash "$SCRIPTS_DIR/benchmark.sh"
        ;;
    backup)
        exec bash "$SCRIPTS_DIR/backup.sh"
        ;;
    restore)
        exec bash "$SCRIPTS_DIR/restore.sh"
        ;;
    optimize)
        cmd_optimize
        ;;
    install)
        cmd_install
        ;;
    uninstall)
        cmd_uninstall
        ;;
    help|-h|--help)
        show_usage
        ;;
    *)
        log_error "Unknown command: '$COMMAND'"
        show_usage
        exit 1
        ;;
esac
